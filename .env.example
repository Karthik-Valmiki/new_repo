# Copy this file to .env and fill in values before running docker compose
# The DB runs inside Docker

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=vero

# Constructed from the above — points to the Docker db service
DATABASE_URL=postgresql://postgres:changeme_strong_password@db:5432/vero

# JWT secret — change this to any long random string
SECRET_KEY=VERO_SRMIST_2026_SECRET
